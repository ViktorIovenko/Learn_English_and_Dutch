# Игнор виртуального окружения и приватных файлов
venv/
.env

# Кэш и временные файлы
__pycache__/
*.pyc
*.pyo
*.pyd
*.db
*.sqlite3

# Настройки VS Code
.vscode/

# Логи
*.log
instance/
*.pid

# Системные файлы
.DS_Store
Thumbs.db

# [ДОБАВЛЕНО] Аудио-генерации (исключаем озвучки из приложения)
# ВАЖНО: путь относительный к корню репозитория, а не абсолютный Windows-путь.
# Полностью исключаем папку с аудиофайлами:
app/static/audio/
# На случай, если где-то заведутся аудио вне этой папки:
*.mp3
*.wav
*.ogg
*.m4a
*.flac
